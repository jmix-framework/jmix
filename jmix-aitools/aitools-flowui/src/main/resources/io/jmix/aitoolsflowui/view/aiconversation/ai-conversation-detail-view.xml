<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://aiConversationDetailView.title"
      focusComponent="form">
    <data>
        <instance id="aiConversationDc"
                  class="io.jmix.aitools.entity.AiConversation">
            <fetchPlan extends="_base"/>
            <loader id="aiConversationDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveCloseAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <formLayout id="form" dataContainer="aiConversationDc">
            <textField id="titleField" property="title"/>
            <comboBox id="usernameField" property="username"/>
        </formLayout>
        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveCloseAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
