<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://aiConversationListView.title">
    <data>
        <collection id="aiConversationsDc"
                    class="io.jmix.aitools.entity.AiConversation">
            <fetchPlan extends="_base"/>
            <loader id="aiConversationsDl" readOnly="true">
                <query>
                    <![CDATA[select e from aitols_AiConversation e order by e.createdDate desc]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <hbox id="buttonsPanel" width="100%">
            <startSlot>
                <button id="createButton" action="aiConversationsDataGrid.createAction"/>
                <button id="editButton" action="aiConversationsDataGrid.editAction"/>
                <button id="removeButton" action="aiConversationsDataGrid.removeAction"/>
            </startSlot>
            <endSlot>
                <simplePagination id="pagination" dataLoader="aiConversationsDl"/>
            </endSlot>
        </hbox>
        <dataGrid id="aiConversationsDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="aiConversationsDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create" />
                <action id="editAction" type="list_edit"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="title" width="60%"/>
                <column property="createdDate" width="40%"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>