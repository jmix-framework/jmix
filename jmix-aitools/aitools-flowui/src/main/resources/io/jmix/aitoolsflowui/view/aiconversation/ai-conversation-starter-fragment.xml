<fragment xmlns="http://jmix.io/schema/flowui/fragment">
    <data>
        <collection id="recentConversationsDc"
                    class="io.jmix.aitools.entity.AiConversation">
            <fetchPlan extends="_base"/>
            <loader id="recentConversationsDl" readOnly="true">
                <query>
                    <![CDATA[select e from aitols_AiConversation e where e.createdBy = :currentUser order by e.createdDate desc]]>
                </query>
            </loader>
        </collection>
        <collection id="historyConversationsDc"
                    class="io.jmix.aitools.entity.AiConversation">
            <fetchPlan extends="_base">
                <property name="messages" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="historyConversationsDl" readOnly="true">
                <query>
                    <![CDATA[select e from aitols_AiConversation e where e.createdBy = :currentUser order by e.createdDate desc]]>
                </query>
            </loader>
        </collection>
    </data>
    <content>
        <vbox id="root"
              width="100%"
              height="100%"
              padding="false"
              spacing="false"
              classNames="ai-conversation-starter">
            <sidePanelLayout id="historySidePanel"
                             width="100%"
                             height="100%"
                             sidePanelPosition="RIGHT"
                             sidePanelOverlay="true"
                             sidePanelHorizontalSize="26rem"
                             modal="false"
                             closeOnOutsideClick="true"
                             classNames="ai-conversation-starter-history-panel">
                <vbox id="starterScrollArea"
                      width="100%"
                      height="100%"
                      padding="false"
                      spacing="false"
                      classNames="ai-conversation-starter-scroll">
                    <vbox id="starterCanvas"
                          width="100%"
                          spacing="true"
                          padding="false"
                          classNames="ai-conversation-starter-canvas">
                        <vbox id="starterHeading"
                              width="100%"
                              spacing="false"
                              padding="false"
                              alignItems="CENTER"
                              classNames="ai-conversation-starter-heading">
                            <div id="starterHeroIcon"
                                 classNames="ai-conversation-starter-hero-icon"/>
                            <h2 id="starterTitle"
                                text="msg://aiConversationStarterFragment.heading"
                                classNames="ai-conversation-starter-title"/>
                            <span id="starterSubtitle"
                                  text="msg://aiConversationStarterFragment.subheading"
                                  classNames="ai-conversation-starter-subtitle"/>
                        </vbox>

                        <vbox id="composerCard"
                              width="100%"
                              spacing="false"
                              padding="false"
                              classNames="ai-conversation-starter-composer">
                            <fragment id="composerFragment"
                                      class="io.jmix.aitoolsflowui.view.aiconversation.composer.AiConversationComposerFragment"/>
                        </vbox>

                        <hbox id="recentConversationsHeader"
                              width="100%"
                              alignItems="CENTER"
                              spacing="false"
                              classNames="ai-conversation-starter-section-header">
                            <h4 id="recentConversationsHeading"
                                text="msg://aiConversationStarterFragment.recentHeading"
                                classNames="ai-conversation-starter-section-heading"/>
                            <div id="recentConversationsSpacer"
                                 classNames="ai-conversation-starter-section-rule"/>
                            <button id="showAllHistoryBtn"
                                    text="msg://aiConversationStarterFragment.showAll"
                                    icon="ANGLE_RIGHT"
                                    iconAfterText="true"
                                    classNames="link-button"/>
                        </hbox>
                        <gridLayout id="recentConversationsGridLayout"
                                    itemsContainer="recentConversationsDc"
                                    width="100%"
                                    columnMinWidth="16rem"
                                    classNames="ai-conversation-starter-recent-grid"/>

                        <!-- Suggestions: scaffold, hidden until implemented. -->
                        <vbox id="suggestionsSection"
                              width="100%"
                              spacing="false"
                              padding="false"
                              visible="false"
                              classNames="ai-conversation-starter-suggestions"/>
                    </vbox>
                </vbox>

                <vbox id="historySidePanelContent"
                      width="100%"
                      height="100%"
                      padding="false"
                      spacing="false"
                      classNames="ai-conversation-starter-history-content">
                    <hbox id="historyPanelHeader"
                          width="100%"
                          alignItems="CENTER"
                          spacing="true"
                          classNames="ai-conversation-starter-history-header">
                        <hbox id="historyPanelTitleGroup"
                              alignItems="CENTER"
                              spacing="false"
                              padding="false"
                              classNames="ai-conversation-starter-history-title-group">
                            <h3 id="historyPanelTitle"
                                text="msg://aiConversationStarterFragment.historyTitle"
                                classNames="ai-conversation-starter-history-title"/>
                            <span id="historyPanelCount"
                                  classNames="ai-conversation-starter-history-count"/>
                        </hbox>
                        <div id="historyHeaderSpacer"
                             classNames="ai-conversation-starter-history-header-spacer"/>
                        <button id="historyNewBtn"
                                text="msg://aiConversationStarterFragment.newConversation"
                                icon="PLUS"
                                themeNames="tertiary small"/>
                        <button id="historyCloseBtn"
                                icon="CLOSE"
                                themeNames="tertiary small icon"
                                ariaLabel="msg://aiConversationStarterFragment.historyClose"/>
                    </hbox>
                    <textField id="historySearchField"
                               valueChangeMode="EAGER"
                               valueChangeTimeout="250"
                               placeholder="msg://aiConversationStarterFragment.historySearchPlaceholder"
                               clearButtonVisible="true"
                               width="100%"
                               classNames="ai-conversation-starter-history-search">
                        <suffix>
                            <icon icon="SEARCH"/>
                        </suffix>
                    </textField>
                    <vbox id="historyListContainer"
                          width="100%"
                          padding="false"
                          spacing="false"
                          classNames="ai-conversation-starter-history-list"/>
                </vbox>
            </sidePanelLayout>
        </vbox>
    </content>
</fragment>
