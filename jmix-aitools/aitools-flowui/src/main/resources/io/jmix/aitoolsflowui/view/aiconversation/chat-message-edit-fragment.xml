<fragment xmlns="http://jmix.io/schema/flowui/fragment">
    <data>
        <instance id="chatMessageDc"
                  class="io.jmix.aitools.entity.ChatMessage"/>
    </data>
    <content>
        <vbox id="root" width="100%" height="100%">
            <hbox width="100%" justifyContent="BETWEEN" alignItems="CENTER">
                <h3 id="header" text="msg://chatMessageEditFragment.header"/>
                <button id="closeButton" icon="lumo:cross" themeNames="tertiary icon contrast"/>
            </hbox>
            <scroller width="100%" height="100%" scrollBarsDirection="VERTICAL">
                <formLayout id="messageForm" dataContainer="chatMessageDc"
                            autoResponsive="true" maxColumns="1"
                            expandColumns="true" expandFields="true" width="100%">
                    <comboBox id="typeField" property="type" required="true"/>
                    <textArea id="contentField" property="content" minHeight="12em"/>
                </formLayout>
            </scroller>
            <hbox>
                <button id="saveButton" text="msg:///actions.Save" themeNames="primary"/>
                <button id="cancelButton" text="msg:///actions.Cancel"/>
            </hbox>
        </vbox>
    </content>
</fragment>
