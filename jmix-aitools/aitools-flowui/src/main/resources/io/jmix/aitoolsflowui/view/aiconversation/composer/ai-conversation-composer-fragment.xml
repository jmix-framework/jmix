<fragment xmlns="http://jmix.io/schema/flowui/fragment">
    <content>
        <vbox id="composerRoot"
              width="100%"
              padding="false"
              spacing="false"
              classNames="ai-conversation-composer">
            <hbox id="inputBar"
                  width="100%"
                  spacing="true"
                  alignItems="END"
                  expand="messageField"
                  classNames="ai-conversation-composer-input-bar">
                <textArea id="messageField"
                          trimEnabled="false"
                          minRows="1"
                          maxRows="6"
                          width="100%"
                          valueChangeMode="EAGER"
                          placeholder="msg://aiConversationComposer.placeholder"
                          classNames="ai-conversation-composer-textarea"/>
                <button id="sendButton"
                        icon="PAPERPLANE"
                        themeNames="primary icon"
                        ariaLabel="msg://aiConversationComposer.send"/>
            </hbox>
        </vbox>
    </content>
</fragment>
