<fragment xmlns="http://jmix.io/schema/flowui/fragment">
    <data>
        <collection id="timelineItemsDc"
                    class="io.jmix.aitoolsflowui.model.TimelineItem"/>
    </data>
    <content>
        <vbox id="root"
              width="100%"
              height="100%"
              spacing="false"
              padding="false"
              classNames="ai-chat-fragment">
            <vbox id="conversationLayout"
                  width="100%"
                  height="100%"
                  spacing="true"
                  padding="false"
                  classNames="chat-layout">
                <hbox id="conversationTitleLayout"
                      width="100%"
                      spacing="false"
                      alignItems="CENTER"
                      classNames="chat-title-layout">
                    <h3 id="conversationTitle"/>
                    <button id="editConversationTitleBtn"
                            icon="PENCIL"
                            themeNames="tertiary icon small"
                            ariaLabel="msg://editConversationTitleAction"/>
                </hbox>
                <vbox id="conversationContentLayout"
                      width="100%"
                      height="100%"
                      spacing="true"
                      padding="false"
                      expand="timelineList"
                      classNames="chat-content-layout">
                    <virtualList id="timelineList"
                                 itemsContainer="timelineItemsDc"
                                 width="100%"
                                 height="100%"
                                 classNames="chat-timeline-list">
                        <fragmentRenderer class="io.jmix.aitoolsflowui.view.chat.renderer.TimelineItemRenderer"/>
                    </virtualList>
                    <vbox id="composerContainer"
                          width="100%"
                          spacing="true"
                          padding="false"
                          classNames="chat-input-container">
                        <fragment id="composerFragment"
                                  class="io.jmix.aitoolsflowui.view.input.AiChatInputFragment"/>
                    </vbox>
                </vbox>
            </vbox>
        </vbox>
    </content>
</fragment>
