<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://aiChatView.title">
    <layout padding="false">
        <vbox id="emptyLayout"
              width="100%"
              height="100%"
              alignItems="CENTER"
              justifyContent="CENTER"
              spacing="true"
              visible="false">
            <icon icon="COMMENT"/>
            <h3 text="msg://aiChatView.empty.title"/>
            <span text="msg://aiChatView.empty.description"/>
            <button id="newChatBtn"
                    text="msg://aiChatView.newChat"
                    icon="PLUS"
                    themeNames="primary"/>
        </vbox>
        <vbox id="notFoundLayout"
              width="100%"
              height="100%"
              alignItems="CENTER"
              justifyContent="CENTER"
              spacing="true"
              visible="false">
            <icon icon="QUESTION_CIRCLE"/>
            <h3 text="msg://aiChatView.notFound.title"/>
            <span text="msg://aiChatView.notFound.description"/>
            <button id="notFoundNewChatBtn"
                    text="msg://aiChatView.newChat"
                    icon="PLUS"
                    themeNames="primary"/>
        </vbox>
        <fragment id="chatFragment"
                  visible="false"
                  class="io.jmix.aitoolsflowui.view.chat.AiChatFragment"/>
    </layout>
</view>
