<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://chatMessageListView.title">
    <data readOnly="true">
        <collection id="chatMessagesDc"
                    class="io.jmix.aitools.entity.ChatMessage">
            <fetchPlan extends="_base"/>
            <loader id="chatMessagesDl">
                <query>
                    <![CDATA[select e from aitols_ChatMessage e order by e.createdDate]]>
                    <condition>
                        <c:jpql>
                            <c:where>e.conversation.id = :conversationId</c:where>
                        </c:jpql>
                    </condition>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <layout expand="chatMessagesDataGrid">
        <hbox width="100%" alignItems="CENTER">
            <h2 id="conversationTitle"/>
        </hbox>
        <hbox wrap="true">
            <propertyFilter property="content" operation="CONTAINS"
                            operationTextVisible="false"
                            dataLoader="chatMessagesDl">
                <textField/>
            </propertyFilter>
            <propertyFilter property="type" operation="EQUAL" dataLoader="chatMessagesDl"
                            operationTextVisible="false"/>
        </hbox>
        <hbox id="buttonsPanel" width="100%">
            <button id="createButton" action="chatMessagesDataGrid.create"/>
            <button id="editButton" action="chatMessagesDataGrid.edit"/>
            <button id="removeButton" action="chatMessagesDataGrid.remove"/>
            <endSlot>
                <simplePagination id="pagination" dataLoader="chatMessagesDl"/>
            </endSlot>
        </hbox>
        <dataGrid id="chatMessagesDataGrid" width="100%" minHeight="20em"
                  dataContainer="chatMessagesDc">
            <actions>
                <action id="create" type="list_create">
                    <properties>
                        <property name="openMode" value="DIALOG"/>
                    </properties>
                </action>
                <action id="edit" type="list_edit">
                    <properties>
                        <property name="openMode" value="DIALOG"/>
                    </properties>
                </action>
                <action id="remove" type="list_remove"/>
            </actions>
            <columns>
                <column property="type" autoWidth="true" flexGrow="0"/>
                <column property="createdDate" autoWidth="true" flexGrow="0"/>
                <column property="content" flexGrow="1"/>
            </columns>
        </dataGrid>
    </layout>
</view>
