<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">
    <changeSet id="1" author="aitols">
        <createTable tableName="AITOLS_AI_CONVERSATION">
            <column name="ID" type="${uuid.type}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="TITLE" type="varchar(255)"/>
            <column name="FIRST_MESSAGE_SENT" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_BY" type="varchar(255)"/>
            <column name="CREATED_DATE" type="datetime"/>
        </createTable>

        <createTable tableName="AITOLS_AI_CONV_ATTACHMENT">
            <column name="ID" type="${uuid.type}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="CONVERSATION_ID" type="${uuid.type}">
                <constraints nullable="false"
                             foreignKeyName="FK_AITOLS_AI_CONV_ATT_CONV"
                             references="AITOLS_AI_CONVERSATION(ID)"/>
            </column>
            <column name="FILE_" type="varchar(1024)">
                <constraints nullable="false"/>
            </column>
            <column name="FILE_NAME" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="TITLE" type="varchar(255)"/>
            <column name="TYPE_" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_BY" type="varchar(255)"/>
            <column name="CREATED_DATE" type="datetime"/>
        </createTable>

        <createIndex tableName="AITOLS_AI_CONV_ATTACHMENT" indexName="IDX_AITOLS_AI_CONV_ATTACH_CONV">
            <column name="CONVERSATION_ID"/>
        </createIndex>

        <createTable tableName="AITOLS_CHAT_MESSAGE">
            <column name="ID" type="${uuid.type}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="CONVERSATION_ID" type="${uuid.type}">
                <constraints nullable="false"
                             foreignKeyName="FK_AITOLS_CHAT_MSG_CONV"
                             references="AITOLS_AI_CONVERSATION(ID)"/>
            </column>
            <column name="CONTENT" type="clob"/>
            <column name="TYPE_" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_BY" type="varchar(255)"/>
            <column name="CREATED_DATE" type="datetime"/>
        </createTable>

        <createIndex tableName="AITOLS_CHAT_MESSAGE" indexName="IDX_AITOLS_CHAT_MESSAGE_CONV">
            <column name="CONVERSATION_ID"/>
        </createIndex>

        <createIndex tableName="AITOLS_CHAT_MESSAGE" indexName="IDX_AITOLS_CHAT_MESSAGE">
            <column name="CONVERSATION_ID"/>
            <column name="CREATED_DATE"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
