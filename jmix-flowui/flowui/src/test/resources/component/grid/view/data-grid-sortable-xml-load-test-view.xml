<view xmlns="http://jmix.io/schema/flowui/view">
    <data>
        <collection id="mainDsEntitiesDc"
                    class="test_support.entity.datastores.MainDsEntity">
            <fetchPlan extends="_base"/>
            <loader id="mainDsEntitiesDl">
                <query>
                    <![CDATA[select e from test_MainDsEntity e]]>
                </query>
            </loader>
        </collection>
        <collection id="mainDsEntitiesDc1"
                    class="test_support.entity.datastores.MainDsEntity">
            <fetchPlan extends="_base"/>
            <loader id="mainDsEntitiesDl1">
                <query>
                    <![CDATA[select e from test_MainDsEntity e]]>
                </query>
            </loader>
        </collection>
        <collection id="mainDsEntitiesDc2"
                    class="test_support.entity.datastores.MainDsEntity">
            <fetchPlan extends="_base"/>
            <loader id="mainDsEntitiesDl2">
                <query>
                    <![CDATA[select e from test_MainDsEntity e]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <layout>
        <dataGrid id="entityDataGrid"
                  dataContainer="mainDsEntitiesDc">
            <columns>
                <column property="name"/>
                <column property="mem1DtoEntity"/>
                <column key="noPropertyColumn"/>
            </columns>
        </dataGrid>

        <dataGrid id="dataGridInMemory"
                  dataContainer="mainDsEntitiesDc1">
            <columns>
                <column property="name"/>
                <column property="mem1DtoEntity" sortable="true"/>
                <column key="noPropertyColumn" sortable="true"/>
            </columns>
        </dataGrid>

        <simplePagination id="simplePaginationPersistent" itemsPerPageDefaultValue="1" dataLoader="mainDsEntitiesDl2"/>
        <dataGrid id="dataGridPersistent"
                  dataContainer="mainDsEntitiesDc2">
            <columns>
                <column property="name"/>
                <column property="mem1DtoEntity" sortable="true"/>
                <column key="noPropertyColumn" sortable="true"/>
            </columns>
        </dataGrid>

        <dataGrid id="dtoDataGrid"
                  metaClass="NoStoreDtoEntity">
            <columns>
                <column property="id"/>
                <column property="name"/>
            </columns>
        </dataGrid>
    </layout>
</view>
