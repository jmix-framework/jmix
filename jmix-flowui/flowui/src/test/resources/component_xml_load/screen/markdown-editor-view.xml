<view xmlns="http://jmix.io/schema/flowui/view">
    <data readOnly="true">
        <instance id="orderDc"
                  class="test_support.entity.sales.Order">
            <fetchPlan extends="_base"/>
            <loader id="orderDl"/>
        </instance>
    </data>
    <layout>
        <markdownEditor id="markdownEditor"
                        ariaLabel="ariaLabelString"
                        ariaLabelledBy="ariaLabelledByString"
                        classNames="cssClassName1, cssClassName2"
                        css="color: red;"
                        enabled="false"
                        errorMessage="errorMessageString"
                        height="50px"
                        helperText="helperTextString"
                        label="labelString"
                        maxHeight="55px"
                        maxWidth="120px"
                        minHeight="40px"
                        minWidth="80px"
                        mode="PREVIEW"
                        placeholder="placeholderString"
                        readOnly="true"
                        required="true"
                        requiredMessage="requiredMessageString"
                        tabIndex="3"
                        themeNames="toolbar-align-center helper-above-field"
                        valueChangeMode="TIMEOUT"
                        valueChangeTimeout="50"
                        visible="false"
                        width="100px">
            <tooltip text="tooltipText"
                     focusDelay="1"
                     hideDelay="2"
                     hoverDelay="3"
                     manual="true"
                     opened="true"
                     position="BOTTOM"/>
        </markdownEditor>

        <markdownEditor id="dataBoundMarkdownEditor"
                        dataContainer="orderDc"
                        property="number"/>
    </layout>
</view>
