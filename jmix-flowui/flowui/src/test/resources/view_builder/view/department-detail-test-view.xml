<view xmlns="http://jmix.io/schema/flowui/view">
    <data>
        <instance id="departmentDc"
                  class="test_support.entity.company.Department">
            <fetchPlan extends="_base">
                <property name="employees" fetchPlan="_base">
                    <property name="department" fetchPlan="_base"/>
                </property>
            </fetchPlan>
            <loader id="departmentDl"/>
            <collection id="employeesDc" property="employees"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveCloseAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <dataGrid id="employeesDataGrid"
                  dataContainer="employeesDc"
                  width="100%"
                  minHeight="20em"
                  selectionMode="MULTI">
            <actions>
                <action id="addAction" type="list_add"/>
                <action id="excludeAction" type="list_exclude"/>
            </actions>
            <columns resizable="true">
                <column property="name"/>
                <column property="department"/>
                <column property="manager"/>
            </columns>
        </dataGrid>
        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveCloseAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
