<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1" author="test">
        <createTable tableName="TEST_LONG_PK_ENTITY">
            <column name="ID" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_TEST_LONG_PK_ENTITY"/>
            </column>
            <column name="NAME" type="VARCHAR(255)"/>
            <column name="UUID" type="UUID"/>
            <column name="VERSION" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="DELETED_BY" type="VARCHAR(255)"/>
            <column name="DELETED_DATE" type="DATETIME"/>
            <column name="CREATED_BY" type="VARCHAR(255)"/>
            <column name="CREATED_DATE" type="DATETIME"/>
        </createTable>
    </changeSet>
    <changeSet id="2" author="test">
        <createTable tableName="TEST_STRING_PK_ENTITY">
            <column name="ID" type="VARCHAR(255)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_TEST_STRING_PK_ENTITY"/>
            </column>
            <column name="NAME" type="VARCHAR(255)"/>
            <column name="UUID" type="UUID"/>
            <column name="VERSION" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="DELETED_BY" type="VARCHAR(255)"/>
            <column name="DELETED_DATE" type="DATETIME"/>
        </createTable>
    </changeSet>
    <changeSet id="3" author="test">
        <createTable tableName="TEST_UUID_PK_ENTITY">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_TEST_UUID_PK_ENTITY"/>
            </column>
            <column name="NAME" type="VARCHAR(255)"/>
            <column name="VERSION" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_BY" type="VARCHAR(255)"/>
            <column name="CREATED_DATE" type="DATETIME"/>
            <column name="DELETED_BY" type="VARCHAR(255)"/>
            <column name="DELETED_DATE" type="DATETIME"/>
        </createTable>
    </changeSet>
    <changeSet id="4" author="test">
        <createTable tableName="TEST_COMPOSITE_PK_ENTITY">
            <column name="NAME" type="VARCHAR(255)"/>
            <column name="UUID" type="UUID"/>
            <column name="VERSION" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_BY" type="VARCHAR(255)"/>
            <column name="CREATED_DATE" type="DATETIME"/>
            <column name="DELETED_BY" type="VARCHAR(255)"/>
            <column name="DELETED_DATE" type="DATETIME"/>
            <column name="PK_NAME" type="VARCHAR(255)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_TEST_COMPOSITE_PK_ENTITY"/>
            </column>
            <column name="PK_VERSION" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_TEST_COMPOSITE_PK_ENTITY"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>