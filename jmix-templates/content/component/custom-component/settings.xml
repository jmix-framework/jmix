<!--
  Custom UI component template.
  Binding variables available to every source below:
    api (TemplateApi), packageName, componentClassName, loaderClassName, registrationClassName,
    studioMetadataClassName, componentFqn, tag, xmlElement, namespace, namespaceAlias,
    jsModulePath, generateFrontend (Boolean)
-->
<template xmlns="http://schemas.haulmont.com/studio/template-settings.xsd"
          order="0"
          name="Custom component">
    <description>
        <![CDATA[<html>Vaadin Flow custom component: server-side component, loader, Spring registration,
        optional Studio metadata and XSD schema, and a LitElement frontend file.</html>]]>
    </description>

    <!--sources: (name, fileExt) is the lookup key used by CustomComponentCreator-->
    <source fileExt="java" name="component"/>
    <source fileExt="kt" name="component"/>

    <source fileExt="java" name="loader"/>
    <source fileExt="kt" name="loader"/>

    <source fileExt="java" name="registration"/>
    <source fileExt="kt" name="registration"/>

    <source fileExt="java" name="studioMetadata"/>
    <source fileExt="kt" name="studioMetadata"/>

    <source fileExt="xsd" name="schema"/>

    <source fileExt="xml" name="schemaElement"/>

    <source fileExt="js" name="frontend"/>
</template>
