<%def isEmbedded(attr) {
        return attr.hasAnnotation('Embedded') || attr.hasAnnotation('EmbeddedId')
}

def columns = []

entity.attributes.each { attr ->
    if (attr == null || !attr.allowPutToDataAware()) {
        return
    }
    if (!isEmbedded(attr)
        && !attr.hasAnnotation('OneToMany')
        && !attr.hasAnnotation('ManyToMany')
        && !columns.contains(attr.name)
        && !attr.isElementCollection()
        && !attr.isDeepInheritor('java.net.URI')) {
        columns << attr.name
    }
}

private String getXmlNamespace() {
     if (tableType.xmlName.contains(':')) {
        def index = tableType.xmlName.indexOf(':') + 1
        return tableType.xmlName.substring(0, index)
     } else {
        return ""
     }
}

def xmlNs = getXmlNamespace()
def isGroupDataGridTable = tableType.getXmlName().equals("groupg:groupDataGrid")

%>
<hbox id="buttonsPanel" classNames="buttons-panel">
<startSlot>
<%tableActions.each { actionId ->%>
<button id="${actionId}Button" action="${tableId}.${actionId}Action"/>
<%}%>
</startSlot>
<endSlot>
<simplePagination id="pagination" dataLoader="${tableDl}"/>
</endSlot>
</hbox>
<${tableType.xmlName} id="${tableId}"
        width="100%"
        minHeight="20em"
        dataContainer="${tableDc}"<%
        if (columnReorderingAllowed) {%>\n columnReorderingAllowed="true"<%}
        if (multiselect) {%>\n selectionMode="MULTI"<%}%>>
<${xmlNs}actions><%tableActions.each { actionId ->
if (actionSearch != null && jmixProjectModule != null) {
def actionDescription = actionSearch.getActionDescriptionBy(actionId, jmixProjectModule)
%>
<${xmlNs}action id="${actionDescription.getId()}Action" type="${actionDescription.getType()}"/>
<%} else {%>
<${xmlNs}action id="${actionId}Action" type="list_${actionId}"/>
<%}%>
<%}%>
</${xmlNs}actions>
<${xmlNs}columns<%if (resizableColumns) {%> resizable="true"<%}%>>
<%if (isGroupDataGridTable) {%><${xmlNs}groupColumn key="groupColumn"/><%}%>
<%columns.each {column ->%>
<${xmlNs}column property="${column}"/>
<%}%>
</${xmlNs}columns>
</${tableType.xmlName}>